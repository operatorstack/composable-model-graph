{
  "name": "composable-model-graph",
  "version": "0.1.0",
  "private": true,
  "description": "Typed transformation graphs with trace, evaluation, and feedback.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "examples": "pnpm -r --workspace-concurrency=1 --filter \"./examples/*\" start",
    "clean": "pnpm -r exec rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
